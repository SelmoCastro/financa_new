# Configurações de Banco de Dados
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"
# Opcional (apenas se usar Prisma Migrate localmente com shadow db)
# DIRECT_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Segurança
JWT_SECRET="sua-chave-secreta-aqui"

# Inteligência Artificial (OpenRouter)
# Obtenha sua chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Configurações de IA (Opcional - Possui Fallback)
AI_TEXT_MODEL="google/gemini-2.0-flash-exp:free"
AI_VISION_MODEL="google/gemini-2.0-flash-exp:free"

# Frontend
FRONTEND_URL="http://localhost:5173"
